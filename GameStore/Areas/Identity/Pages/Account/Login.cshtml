@page
@model LoginModel
@{
    ViewData["Title"] = "Logowanie";
}

<h1 class="mb-4">@ViewData["Title"]</h1>
<div class="row">
    <div class="col-md-5">
        <div class="gs-panel">
            <form id="account" method="post">
                <h2 class="gs-section-title">Zaloguj się</h2>
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">E-mail</label>
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="nazwa@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">Hasło</label>
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="hasło" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <label class="form-check-label" asp-for="Input.RememberMe">Zapamiętaj mnie</label>
                </div>
                <button id="login-submit" type="submit" class="gs-btn w-100">Zaloguj</button>
                <div class="mt-3">
                    <p class="mb-0"><a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Załóż nowe konto</a></p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
