@model GameStore.Models.DbModels.Game
@{
    ViewData["Title"] = "Dodaj grę";
}
<h1 class="mb-3">Dodaj nową grę</h1>
<div class="gs-panel">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <partial name="_GameForm" model="Model" />
        <div class="mt-3">
            <button type="submit" class="gs-btn">Zapisz</button>
            <a class="gs-btn-ghost btn ms-2" asp-action="Index">Anuluj</a>
        </div>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
