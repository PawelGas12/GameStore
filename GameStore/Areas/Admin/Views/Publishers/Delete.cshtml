@model GameStore.Models.DbModels.Publisher
@{
    ViewData["Title"] = "Usuń wydawcę";
}
<h1 class="mb-3 text-danger">Usuń wydawcę</h1>
<div class="gs-panel" style="max-width:480px;">
    <p>Czy na pewno usunąć wydawcę <strong>@Model.Name</strong>?</p>
    <form asp-action="Delete" method="post">
        <input type="hidden" name="id" value="@Model.PublisherId" />
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">Tak, usuń</button>
        <a class="gs-btn-ghost btn ms-2" asp-action="Index">Anuluj</a>
    </form>
</div>
